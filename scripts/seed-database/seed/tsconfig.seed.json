{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "outDir": "../seed-dist",
    "esModuleInterop": true,
    "strict": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "..",
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": ["*.ts", "../lib/definitions.ts"]
}